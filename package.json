{
  "name": "ralph-qa-harness",
  "version": "0.1.0",
  "description": "Artifact-first standalone npm CLI for Playwright BDD QA workflows with a narrow, documented target-project contract.",
  "main": "./scripts/qa-harness.js",
  "bin": {
    "ralph-qa-harness": "./bin/ralph-qa-harness.js"
  },
  "type": "commonjs",
  "scripts": {
    "test": "node --test --test-isolation=none tests/harness/qa-harness.test.js tests/doctor.test.js tests/bin.test.js tests/package.test.js",
    "qa:orchestrator": "node ./scripts/qa-orchestrator.js",
    "cli": "node ./bin/ralph-qa-harness.js"
  },
  "files": [
    "bin",
    "scripts",
    "templates",
    "docs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "qa",
    "playwright",
    "playwright-bdd",
    "cli",
    "artifact-first"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright-bdd": "^8.5.0"
  }
}
