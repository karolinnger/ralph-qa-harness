# Optional target-project execution defaults
# PLAYWRIGHT_BASE_URL=https://playwright.dev
# QA_HARNESS_TARGET_ENV=staging

# Optional external runtime override.
# Leave unset to use the bundled `scripts/qa-runtime-external-worker.js`.
# QA_HARNESS_EXTERNAL_RUNTIME_CMD=node
# QA_HARNESS_EXTERNAL_RUNTIME_ARGS=["/absolute/path/to/custom-runtime-worker.js"]

# Optional Playwright test/debug bridge.
# Configure only if your runtime asks for the bridge.
# QA_HARNESS_PLAYWRIGHT_BRIDGE_CMD=node
# QA_HARNESS_PLAYWRIGHT_BRIDGE_ARGS=["/absolute/path/to/custom-bridge.js"]

